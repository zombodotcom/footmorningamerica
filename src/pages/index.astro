---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { anonClient } from '../lib/supabase';
import { getApprovedListings } from '../lib/listings.repo';
import { buildCreatorUrl, buildPlatformSignupUrl } from '../lib/affiliate';
import RankRow from '../components/RankRow.astro';
import FeedCard from '../components/FeedCard.astro';
import SectionHead from '../components/SectionHead.astro';

const feetfinderUrl = buildPlatformSignupUrl('feetfinder');

const feed = [
  { kind: 'cover', title: 'She looked down. What she saw will shock you.', sub: '(It was feet.)' },
  { kind: 'forecast', title: 'Today: 73°, light breeze, 100% chance of sandals.' },
  { kind: 'quote', title: '“I have two of them.”', sub: '— Local man, on his feet' },
  { kind: 'stars', title: 'New Arch Rating', sub: '★★★★★' },
  { kind: 'breaking', title: 'Sock market crashes as summer arrives' },
  { kind: 'classified', title: 'WANTED: someone to appreciate these feet. Will travel.' },
  { kind: 'cover', title: 'Exclusive: the toes America is talking about' },
  { kind: 'quote', title: '“Best site I never told anyone I visit.”', sub: '— Anonymous reader' },
  { kind: 'forecast', title: 'Extended toe-cast: sunny through the weekend.' },
  { kind: 'breaking', title: 'Study: looking at feet is “probably fine,” scientists shrug' },
  { kind: 'stars', title: 'Footy Approved', sub: '★★★★★' },
  { kind: 'classified', title: 'FOR SALE: pristine feet pics. Inquire within (the directory).' },
];

const steps = [
  { n: '1', label: 'Discover', note: 'Browse foot creators in the directory, free.' },
  { n: '2', label: 'Follow', note: 'Support them on their own platform.' },
  { n: '3', label: 'Get listed', note: 'Creators: submit your profile to be featured.' },
];

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

// Creator of the Week — newest approved listing (resilient if Supabase hiccups).
let cotw = null;
try {
  const approved = await getApprovedListings(anonClient());
  cotw = approved[0] ?? null;
} catch {
  cotw = null;
}

const tickerItems = [
  'Local man owns two feet, reportedly “normal about it”',
  'Sandal futures soar on humid forecast',
  'Sock industry “concerned,” sources say',
  'Footy spotted buying lotion in bulk',
  'Nation’s arches at all-time high',
];

// Parody power rankings — public figures rated for laughs, à la WikiFeet culture.
const rankings = [
  { name: 'Emma Stone', stars: '★★★★★', trend: '—', note: 'Critics agree: best arches in the business.' },
  { name: 'Emma Watson', stars: '★★★★★', trend: '▲', note: 'A perennial powerhouse.' },
  { name: 'Selena Gomez', stars: '★★★★☆', trend: '▲', note: 'Surging in the polls this week.' },
  { name: 'Taylor Swift', stars: '★★★★☆', trend: '▲', note: 'Cracked the top 10. Swifties mobilizing.' },
  { name: 'Margot Robbie', stars: '★★★★☆', trend: '▼', note: 'Slight dip. Still box-office feet.' },
  { name: 'Mila Kunis', stars: '★★★★☆', trend: '▲', note: 'Quiet climber, No. 19 and rising.' },
];
---
<Base title="Foot Morning America — America's Foot-Content Directory">
  <!-- Breaking ticker -->
  <div class="ticker -mx-4 bg-red px-4 py-2 text-paper">
    <div class="ticker-track">
      {[...tickerItems, ...tickerItems].map((t) => (
        <span class="dateline text-xs">★ Breaking Soles: {t}</span>
      ))}
    </div>
  </div>

  <!-- Lead story -->
  <section class="grid gap-8 py-12 lg:grid-cols-[1.6fr_1fr] lg:gap-12">
    <div>
      <p class="stamp text-sm">Extra! Extra!</p>
      <h1 class="mt-5 text-5xl sm:text-7xl">Every good foot, in one place.</h1>
      <p class="mt-5 max-w-prose text-lg leading-relaxed">
        <span class="font-semibold">Foot Morning America</span> is the free directory of the
        internet's foot creators. Browse them here, then follow and support them on their own
        platforms. Your host: <span class="font-semibold">Footy</span>.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/directory" class="border-2 border-ink bg-ink px-7 py-3 text-lg uppercase tracking-wide text-paper hover:bg-red" style="font-family: var(--font-headline)">Browse the Directory →</a>
        <a href="/get-featured" class="border-2 border-ink px-7 py-3 text-lg uppercase tracking-wide hover:bg-paper-dim" style="font-family: var(--font-headline)">Get Featured →</a>
      </div>
    </div>

    <!-- Footy "file photo" -->
    <figure class="print-card self-start border-2 border-ink">
      <p class="star-band dateline px-3 py-1 text-center text-[10px] tracking-[0.25em]">★ America's Host ★</p>
      <div class="bg-white">
        <img src="/img/footy-logo.jpg" alt="Footy, the foot-headed host of Foot Morning America" class="mx-auto block max-h-72 w-auto object-contain sm:max-h-80" loading="lazy" decoding="async" />
      </div>
      <figcaption class="dateline border-t border-ink px-3 py-2 text-[11px]">
        File photo: Footy, your host. (Actual feet may vary.)
      </figcaption>
    </figure>
  </section>

  <!-- Photo strip -->
  <section class="pb-4">
    <div class="grid grid-cols-3 gap-2 sm:gap-4">
      <img src="/img/feet-sand.jpg" alt="" class="h-28 w-full border-2 border-ink object-cover sm:h-56" loading="lazy" decoding="async" />
      <img src="/img/feet-cozy.jpg" alt="" class="h-28 w-full border-2 border-ink object-cover sm:h-56" loading="lazy" decoding="async" />
      <img src="/img/feet-sandals.jpg" alt="" class="h-28 w-full border-2 border-ink object-cover sm:h-56" loading="lazy" decoding="async" />
    </div>
  </section>

  <!-- Power rankings + Creator of the Week -->
  <section class="grid gap-8 py-12 lg:grid-cols-[1.6fr_1fr] lg:gap-12">
    <div>
      <SectionHead
        eyebrow="This Week in Feet"
        title="Foot Power Rankings"
        sub="The nation's most-talked-about feet, ranked by our crack team of nobody."
        href="/feet-of-fame"
        linkText="Full rankings →"
      />
      <ol>
        {rankings.map((r, i) => (
          <RankRow rank={i + 1} name={r.name} stars={r.stars} trend={r.trend} note={r.note} />
        ))}
      </ol>
      <p class="dateline mt-3 text-[10px] text-ink/50">Rankings are a joke and a parody. Feet belong to their owners.</p>
    </div>

    <!-- Creator of the Week -->
    <aside class="print-card self-start border-2 border-ink">
      <p class="star-band dateline px-3 py-1 text-center text-[11px] tracking-[0.2em]">★ Creator of the Week ★</p>
      <div class="halftone flex items-center justify-center bg-paper-dim py-8 text-7xl">👣</div>
      <div class="border-t border-ink p-4">
        {cotw ? (
          <>
            <h3 class="text-2xl leading-none">{cotw.display_name}</h3>
            <p class="dateline mt-1 text-xs text-ink/70">@{cotw.handle}</p>
            {cotw.bio && <p class="mt-2 text-sm leading-relaxed">{cotw.bio}</p>}
            <a href={buildCreatorUrl(cotw.outbound_url)} rel="nofollow noopener" target="_blank" class="mt-4 block border-2 border-ink bg-ink px-4 py-2 text-center text-sm uppercase tracking-wide text-paper hover:bg-red" style="font-family: var(--font-headline)">View profile →</a>
          </>
        ) : (
          <>
            <h3 class="text-2xl leading-tight">This spot's open.</h3>
            <p class="mt-2 text-sm leading-relaxed">No creator featured yet. It could be you — get in the directory and Footy might just crown you.</p>
            <a href="/get-featured" class="mt-4 block border-2 border-ink bg-ink px-4 py-2 text-center text-sm uppercase tracking-wide text-paper hover:bg-red" style="font-family: var(--font-headline)">Get Featured →</a>
          </>
        )}
      </div>
    </aside>
  </section>

  <!-- The Feed (meme wall) -->
  <section class="py-12">
    <SectionHead eyebrow="Straight off Footy's desk" title="The Feed" />
    <div class="columns-2 gap-4 sm:columns-3">
      {feed.map((c) => <FeedCard kind={c.kind} title={c.title} sub={c.sub} />)}
    </div>
    <p class="dateline mt-2 text-[10px] text-ink/50">Updated constantly.* (*Footy's definition of "constantly" may differ from yours.)</p>
  </section>

  <!-- How it works -->
  <section class="py-12">
    <SectionHead title="How it works" />
    <div class="sm:grid sm:grid-cols-3 sm:gap-6">
      {steps.map((s) => (
        <div class="flex items-center gap-4 border-t border-ink/20 py-4 first:border-t-0 first:pt-0 sm:flex-col sm:items-start sm:border-t-0 sm:py-0 sm:first:pt-0">
          <span class="shrink-0 text-4xl text-red sm:text-5xl" style="font-family: var(--font-headline)">{s.n}</span>
          <div>
            <p class="text-xl leading-none" style="font-family: var(--font-headline)">{s.label}</p>
            <p class="mt-1 text-sm text-ink/70">{s.note}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- For creators CTA -->
  <section class="py-2">
    <div class="print-card border-2 border-ink">
      <p class="star-band dateline px-4 py-1.5 text-center text-[11px] tracking-[0.2em]">★ Calling All Creators ★</p>
      <div class="grid gap-6 p-6 sm:grid-cols-[1.4fr_1fr] sm:items-center sm:p-8">
        <div>
          <h2 class="text-3xl sm:text-4xl">Turn feet into income.</h2>
          <p class="mt-2 leading-relaxed text-ink/80">Get listed in the directory for free, or start your own foot-content shop. Footy roots for you either way.</p>
        </div>
        <div class="flex flex-col gap-3">
          <a href="/get-featured" class="border-2 border-ink bg-ink px-5 py-3 text-center text-base uppercase tracking-wide text-paper hover:bg-red" style="font-family: var(--font-headline)">Get Featured Free →</a>
          <a href={feetfinderUrl} rel="nofollow noopener sponsored" target="_blank" class="border-2 border-ink px-5 py-3 text-center text-base uppercase tracking-wide hover:bg-paper-dim" style="font-family: var(--font-headline)">Start Selling on FeetFinder →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- From the newsroom -->
  <section class="py-12">
    <SectionHead eyebrow="Latest" title="From the Newsroom" href="/news" linkText="All news →" />
    <div class="grid gap-6 sm:grid-cols-3">
      {posts.map((post) => (
        <a href={`/news/${post.id}`} class="print-hover block border-2 border-ink bg-paper">
          {post.data.heroImage && (
            <img src={post.data.heroImage} alt="" class="h-36 w-full border-b-2 border-ink object-cover" loading="lazy" decoding="async" />
          )}
          <div class="p-4">
            <p class="dateline text-[11px] text-ink/60">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}
            </p>
            <h3 class="mt-1 text-xl leading-tight">{post.data.title}</h3>
            <p class="mt-2 text-sm leading-relaxed">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
