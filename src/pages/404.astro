---
import Base from '../layouts/Base.astro';
---
<Base title="404 — Foot Morning America" description="This page got cold feet.">
  <section class="mx-auto max-w-2xl py-20 text-center">
    <p class="stamp text-sm">Stop the Press</p>
    <h1 class="mt-5 text-6xl sm:text-7xl">404</h1>
    <p class="mt-2 text-2xl" style="font-family: var(--font-headline)">This page got cold feet.</p>
    <p class="mt-3 text-ink/70">It wandered off, or it never existed. Either way, it's not here.</p>
    <a href="/" class="mt-7 inline-block border-2 border-ink bg-ink px-8 py-3 text-lg uppercase tracking-wide text-paper hover:bg-red" style="font-family: var(--font-headline)">Back to the Front Page →</a>
  </section>
</Base>
