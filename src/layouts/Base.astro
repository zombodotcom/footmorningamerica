---
import Footer from '../components/Footer.astro';
import AgeGate from '../components/AgeGate.astro';
import '../styles/global.css';
const { title = 'Foot Morning America', gated = false } = Astro.props;
const path = Astro.url.pathname;
const sections = [
  { href: '/', label: 'Home' },
  { href: '/feet-of-fame', label: 'Fame' },
  { href: '/news', label: 'News' },
  { href: '/directory', label: 'Directory' },
  { href: '/get-featured', label: 'Get Featured' },
];
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Spectral:ital,wght@0,400;0,600;0,800;1,400&family=Special+Elite&family=UnifrakturCook:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <!-- Old-glory stripe band -->
    <div class="flag-stripes h-2.5 w-full"></div>

    <header class="mx-auto max-w-6xl px-4 pt-3 sm:pt-4">
      <!-- Masthead -->
      <div class="grid grid-cols-1 items-end gap-1 pb-2 sm:grid-cols-3 sm:gap-2">
        <p class="dateline hidden text-[10px] leading-tight sm:block sm:text-xs">
          Vol. I — No. 1<br />Weekend Edition<br />Est. This Morning
        </p>
        <p style="font-family: var(--font-masthead)" class="text-center text-4xl leading-none sm:text-5xl">
          <a href="/">Foot Morning America</a>
        </p>
        <p class="dateline hidden text-right text-[10px] leading-tight sm:block sm:text-xs">
          Price: Free<br />Forecast: Toes Out<br />Weather: Humid
        </p>
      </div>
      <!-- Star band -->
      <div class="star-band -mx-4 px-4 py-1 text-center">
        <p class="dateline text-[9px] tracking-[0.3em] sm:text-[11px] sm:tracking-[0.35em]">
          ★ ★ ★&ensp;The United States of Feet&ensp;★ ★ ★
        </p>
      </div>
      <!-- Section index -->
      <nav class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 py-2 text-xs uppercase sm:gap-x-6 sm:text-sm" aria-label="Sections">
        {sections.map((s) => (
          <a
            href={s.href}
            class:list={[
              'dateline transition-colors hover:text-red',
              isActive(s.href) ? 'text-red underline underline-offset-4' : 'text-ink',
            ]}
            aria-current={isActive(s.href) ? 'page' : undefined}
          >{s.label}</a>
        ))}
      </nav>
      <div class="rule-double"></div>
    </header>

    <main class="mx-auto max-w-6xl px-4"><slot /></main>

    <Footer />
    {gated && <AgeGate />}
  </body>
</html>
