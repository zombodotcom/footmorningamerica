---
import Base from '../layouts/Base.astro';
---
<Base title="Foot Morning America — America's Foot-Content Directory">
  <section class="mx-auto max-w-4xl px-6 py-20 text-center">
    <p class="text-sm font-bold uppercase tracking-widest text-red-600">Good morning, America 🦶</p>
    <h1 class="mt-4 text-5xl font-black leading-tight">Foot Morning America</h1>
    <p class="mt-4 text-xl text-neutral-600">
      Meet <strong>Footy</strong> — your guide to the best foot creators on the internet.
      Discover them here, then follow and support them on their own platforms.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="/directory" class="rounded bg-black px-8 py-4 font-bold text-white">Browse the Directory</a>
      <a href="/get-featured" class="rounded border-2 border-black px-8 py-4 font-bold">Get Featured</a>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-20">
    <h2 class="text-2xl font-black">How it works</h2>
    <ul class="mt-4 grid gap-4 sm:grid-cols-3">
      <li class="rounded-lg border p-4">
        <strong>1. Discover</strong>
        <p class="text-sm text-neutral-500">Browse foot creators in the directory, free.</p>
      </li>
      <li class="rounded-lg border p-4">
        <strong>2. Follow</strong>
        <p class="text-sm text-neutral-500">Head to their platform to subscribe and support.</p>
      </li>
      <li class="rounded-lg border p-4">
        <strong>3. Get listed</strong>
        <p class="text-sm text-neutral-500">A creator? Submit your profile to get featured.</p>
      </li>
    </ul>
  </section>
</Base>
