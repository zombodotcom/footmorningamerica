---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const dateStr = post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={`${post.data.title} — Foot Morning America`} description={post.data.description}>
  <article class="mx-auto max-w-2xl py-8">
    <a href="/news" class="dateline text-xs underline hover:text-red">← All foot news</a>
    <p class="dateline mt-4 text-xs text-red">Foot News Wire · {dateStr}</p>
    <h1 class="mt-1 text-4xl leading-tight sm:text-5xl">{post.data.title}</h1>
    <p class="mt-3 border-l-4 border-red pl-4 text-lg italic leading-relaxed text-ink/80">{post.data.description}</p>
    {post.data.heroImage && (
      <img src={post.data.heroImage} alt="" class="print-card mt-6 h-60 w-full border-2 border-ink object-cover sm:h-80" loading="lazy" decoding="async" />
    )}
    <div class="rule-double mt-5"></div>
    <div class="article-body mt-5 text-[1.05rem]">
      <Content />
    </div>
    <div class="rule-thin mt-8"></div>
    <p class="dateline mt-3 text-xs text-ink/60">— 30 —</p>
  </article>
</Base>
