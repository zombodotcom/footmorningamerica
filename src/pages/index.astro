---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const tickerItems = [
  'Local man owns two feet, reportedly “normal about it”',
  'Sandal futures soar on humid forecast',
  'Sock industry “concerned,” sources say',
  'Footy spotted buying lotion in bulk',
  'Nation’s arches at all-time high',
];
---
<Base title="Foot Morning America — America's Foot-Content Directory">
  <!-- Breaking ticker -->
  <div class="ticker -mx-4 mb-4 bg-red px-4 py-2 text-paper">
    <div class="ticker-track">
      {[...tickerItems, ...tickerItems].map((t) => (
        <span class="dateline text-xs">★ Breaking Soles: {t}</span>
      ))}
    </div>
  </div>

  <!-- Lead story -->
  <section class="grid gap-6 pb-8 lg:grid-cols-[1.6fr_1fr]">
    <div>
      <p class="stamp text-sm">Extra! Extra!</p>
      <h1 class="mt-4 text-5xl sm:text-7xl">Every good foot, in one place.</h1>
      <p class="mt-4 max-w-prose text-lg leading-relaxed">
        <span class="font-semibold">Foot Morning America</span> is the free directory of the
        internet's foot creators. Browse them here, then follow and support them on their own
        platforms. Your host: <span class="font-semibold">Footy</span>.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/directory" class="border-2 border-ink bg-ink px-7 py-3 text-lg uppercase tracking-wide text-paper hover:bg-red" style="font-family: var(--font-headline)">Browse the Directory →</a>
        <a href="/get-featured" class="border-2 border-ink px-7 py-3 text-lg uppercase tracking-wide hover:bg-paper-dim" style="font-family: var(--font-headline)">Get Featured →</a>
      </div>
    </div>

    <!-- Footy "file photo" -->
    <figure class="self-start border-2 border-ink">
      <p class="star-band dateline px-3 py-1 text-center text-[10px] tracking-[0.25em]">★ America's Host ★</p>
      <div class="halftone flex items-center justify-center bg-paper-dim py-8 text-8xl">🦶</div>
      <figcaption class="dateline border-t border-ink px-3 py-2 text-[11px]">
        File photo: Footy, your host. (Actual feet may vary.)
      </figcaption>
    </figure>
  </section>

  <div class="rule-double"></div>

  <!-- How it works, as columns -->
  <section class="grid gap-x-8 gap-y-6 py-8 sm:grid-cols-3">
    <div>
      <p class="dateline text-xs text-red">Section A</p>
      <h3 class="mt-1 text-2xl">Discover</h3>
      <p class="mt-2 leading-relaxed">Browse foot creators in the directory — free, no signup, no nonsense.</p>
    </div>
    <div class="sm:border-l sm:border-ink/30 sm:pl-8">
      <p class="dateline text-xs text-red">Section B</p>
      <h3 class="mt-1 text-2xl">Follow</h3>
      <p class="mt-2 leading-relaxed">Head to a creator's own platform to subscribe and support them directly.</p>
    </div>
    <div class="sm:border-l sm:border-ink/30 sm:pl-8">
      <p class="dateline text-xs text-red">Section C</p>
      <h3 class="mt-1 text-2xl">Get listed</h3>
      <p class="mt-2 leading-relaxed">A creator? Submit your profile and Footy will review it for the directory.</p>
    </div>
  </section>

  <div class="rule-double"></div>

  <!-- From the newsroom -->
  <section class="py-8">
    <div class="mb-4 flex items-baseline justify-between">
      <h3 class="text-3xl">From the Newsroom</h3>
      <a href="/news" class="dateline shrink-0 whitespace-nowrap text-xs underline hover:text-red sm:text-sm">All news →</a>
    </div>
    <div class="grid gap-6 sm:grid-cols-3">
      {posts.map((post) => (
        <a href={`/news/${post.id}`} class="block border border-ink/40 p-4 hover:bg-paper-dim">
          <p class="dateline text-[11px] text-ink/60">
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}
          </p>
          <h4 class="mt-1 text-xl leading-tight">{post.data.title}</h4>
          <p class="mt-2 text-sm leading-relaxed">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
