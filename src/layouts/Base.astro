---
import Footer from '../components/Footer.astro';
import AgeGate from '../components/AgeGate.astro';
// Self-hosted fonts (served from our own origin — reliable on mobile, no Google CDN dependency).
import '@fontsource/unifrakturcook/700.css';
import '@fontsource/anton';
import '@fontsource/special-elite';
import '@fontsource/spectral/400.css';
import '@fontsource/spectral/400-italic.css';
import '@fontsource/spectral/600.css';
import '@fontsource/spectral/800.css';
import '../styles/global.css';
const {
  title = 'Foot Morning America',
  description = "America's free directory of foot creators — plus Footy's foot news, power rankings, and the feed. Discover creators here, follow them on their own platforms.",
  image = '/og.png',
  gated = false,
} = Astro.props;
const path = Astro.url.pathname;
const canonical = new URL(path, Astro.site);
const ogImage = new URL(image, Astro.site);
const cfToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
const sections = [
  { href: '/', label: 'Home' },
  { href: '/feet-of-fame', label: 'Fame' },
  { href: '/news', label: 'News' },
  { href: '/directory', label: 'Directory' },
  { href: '/get-featured', label: 'Get Featured' },
];
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#c8102e" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Foot Morning America" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="min-h-screen">
    <!-- Utility bar -->
    <div class="bg-navy text-paper">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-1.5">
        <p class="dateline text-[10px] tracking-wider">Weekend Edition</p>
        <p class="dateline hidden text-[10px] tracking-wider sm:block">America's Foot-Content Directory</p>
        <p class="dateline text-[10px] tracking-wider">Forecast: Toes Out</p>
      </div>
    </div>
    <!-- Flag accent -->
    <div class="flag-stripes h-2 w-full"></div>

    <!-- Masthead -->
    <header class="mx-auto max-w-6xl px-4 pb-5 pt-7 text-center sm:pt-9">
      <a href="/" style="font-family: var(--font-masthead)" class="inline-block text-5xl leading-none sm:text-6xl">Foot Morning America</a>
      <p class="dateline mt-3 text-[10px] tracking-[0.35em] text-ink/55 sm:text-[11px]">★&ensp;The United States of Feet&ensp;★</p>
    </header>

    <!-- Sticky section nav -->
    <nav class="sticky top-0 z-40 border-y-2 border-ink bg-paper/90 backdrop-blur" aria-label="Sections">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-4 gap-y-1 px-4 py-3 text-xs uppercase sm:gap-x-7 sm:text-sm">
        {sections.map((s) => (
          <a
            href={s.href}
            class:list={[
              'dateline relative pb-1 transition-colors',
              isActive(s.href) ? 'text-red' : 'text-ink hover:text-red',
            ]}
            aria-current={isActive(s.href) ? 'page' : undefined}
          >
            {s.label}
            {isActive(s.href) && <span class="absolute -bottom-[3px] left-0 h-[3px] w-full bg-red"></span>}
          </a>
        ))}
      </div>
    </nav>

    <main class="mx-auto max-w-6xl px-4 pt-4"><slot /></main>

    <Footer />
    {gated && <AgeGate />}
    {cfToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfToken}"}`}
      ></script>
    )}
  </body>
</html>
