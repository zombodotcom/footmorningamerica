---
<div
  id="age-gate"
  data-testid="age-gate"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-ink/95 p-4"
>
  <div class="halftone w-full max-w-md border-4 border-paper bg-paper p-1">
    <div class="border-2 border-ink bg-paper p-8 text-center">
      <p class="stamp mx-auto text-sm">Press Credential</p>
      <h2 class="mt-5 text-3xl">Are you 18?</h2>
      <p class="mt-3 leading-relaxed">
        Foot Morning America links to content intended for adults. By entering you affirm you are
        18 years of age or older.
      </p>
      <button id="age-ok" class="mt-6 w-full border-2 border-ink bg-ink px-6 py-3 font-[var(--font-headline)] text-lg uppercase tracking-wide text-paper transition-colors hover:bg-red">
        I am 18 or older
      </button>
      <p class="dateline mt-3 text-[11px] text-ink/60">Otherwise, kindly exit the newsstand.</p>
    </div>
  </div>
</div>
<script>
  const KEY = 'fma-age-ok';
  const gate = document.getElementById('age-gate')!;
  if (localStorage.getItem(KEY) !== 'yes') gate.classList.replace('hidden', 'flex');
  document.getElementById('age-ok')?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'yes');
    gate.classList.replace('flex', 'hidden');
  });
</script>
