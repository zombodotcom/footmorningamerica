<Base title="Terms — Foot Morning America">
  <section class="mx-auto max-w-2xl px-6 py-12">
    <h1 class="text-3xl font-black">Terms of Use</h1>
    <p class="mt-4 text-neutral-700">
      You must be 18 or older to use the directory. Listings are submitted by creators and link to
      third-party platforms. We do not control or endorse third-party content. We reserve the right
      to remove any listing at our discretion.
    </p>
  </section>
</Base>
