---
const { kind, title, sub } = Astro.props;
const tilt = ['-rotate-1', 'rotate-1', '-rotate-2', 'rotate-2', 'rotate-0'];
const r = tilt[title.length % tilt.length];
const base = `break-inside-avoid mb-4 border-2 border-ink p-4 ${r}`;
---
{kind === 'cover' && (
  <div class:list={[base, 'bg-paper']}>
    <p class="stamp text-[10px]">Exclusive</p>
    <p class="mt-3 text-xl leading-tight" style="font-family: var(--font-headline)">{title}</p>
    {sub && <p class="mt-1 text-sm italic">{sub}</p>}
  </div>
)}
{kind === 'breaking' && (
  <div class:list={[base, 'bg-red text-paper']}>
    <p class="dateline text-[10px]">Breaking Soles</p>
    <p class="mt-2 text-lg leading-tight" style="font-family: var(--font-headline)">{title}</p>
  </div>
)}
{kind === 'forecast' && (
  <div class:list={[base, 'star-band']}>
    <p class="dateline text-[10px]">Footy's Forecast</p>
    <p class="mt-2 text-base leading-snug">{title}</p>
  </div>
)}
{kind === 'quote' && (
  <div class:list={[base, 'bg-paper-dim']}>
    <p class="text-lg italic leading-snug">{title}</p>
    {sub && <p class="dateline mt-2 text-[11px] text-ink/70">{sub}</p>}
  </div>
)}
{kind === 'stars' && (
  <div class:list={[base, 'bg-paper text-center']}>
    <p class="dateline text-[10px] text-red">{title}</p>
    <p class="mt-2 text-2xl text-gold">{sub}</p>
  </div>
)}
{kind === 'classified' && (
  <div class:list={[base, 'halftone bg-paper-dim']}>
    <div class="bg-paper p-3">
      <p class="dateline text-[10px] text-ink/60">Classified</p>
      <p class="mt-1 text-sm leading-snug">{title}</p>
    </div>
  </div>
)}
