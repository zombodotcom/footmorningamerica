---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---
<Base title="News — Foot Morning America">
  <section class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-3xl font-black">Foot News, with Footy</h1>
    <p class="mt-2 text-neutral-500">{posts.length} dispatches from the front lines of feet.</p>
    <ul class="mt-8 grid gap-6">
      {posts.map((post) => (
        <li class="rounded-lg border border-neutral-200 p-5">
          <a href={`/news/${post.id}`} class="text-xl font-bold underline">{post.data.title}</a>
          <p class="mt-1 text-sm text-neutral-500">
            {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <p class="mt-2 text-neutral-700">{post.data.description}</p>
        </li>
      ))}
    </ul>
  </section>
</Base>
