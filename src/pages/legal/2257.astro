---
import Base from '../../layouts/Base.astro';
---
<Base title="2257 Statement — Foot Morning America">
  <section class="mx-auto max-w-2xl px-6 py-12">
    <h1 class="text-3xl font-black">18 U.S.C. § 2257 Statement</h1>
    <p class="mt-4 text-neutral-700">
      Foot Morning America does not produce, host, or store any sexually explicit content. The site
      functions solely as a directory linking to third-party platforms. We are not a "producer" of
      any content within the meaning of 18 U.S.C. § 2257. All records required by law for content
      are maintained by the third-party producers and platforms that host it.
    </p>
  </section>
</Base>
